---
import CartIcon from './CartIcon.tsx';
---

<header class="vb-header">
  <div class="vb-header__row">
    <a href="/" class="vb-brand">
      <img src="/assets/vagabound-logo.svg" alt="" class="vb-brand__mark" width="52" height="52">
      <span class="vb-brand__wm">
        <span class="name">Vagabound</span>
        <span class="meta">A home for migratory words.</span>
      </span>
    </a>

    <nav class="vb-nav">
      <a href="/" class="vb-nav__link">Shop</a>
      <a href="/collections" class="vb-nav__link">Collections</a>
      <a href="/field-notes" class="vb-nav__link">Field Notes</a>
      <a href="/#sell-to-us" class="vb-nav__link">Sell to us</a>
    </nav>

    <form action="/search" method="get" class="vb-search-btn" role="search">
      <input type="hidden" name="type" value="product">
      <span class="glyph">⌕</span>
      <input type="search" name="q" placeholder="Search the shelves" aria-label="Search the shelves" autocomplete="off" class="vb-search-input">
      <span class="kbd">/</span>
    </form>

    <div class="vb-actions">
      <a href="/pages/shelf" class="vb-iconbtn" aria-label="Shelf">
        <svg id="fi_5519523" enable-background="new 0 0 505.736 505.736" viewBox="0 0 505.736 505.736" xmlns="http://www.w3.org/2000/svg" width="22" height="22"><g><g><path d="m368.209 152.271h47.445v106.631h-47.445z"></path><path d="m222.003 152.271h47.445v106.631h-47.445z"></path><path d="m203.484 143.011v115.891h-47.439v-145.126h47.439z"></path><path d="m90.094 113.776h47.439v145.126h-47.439z"></path><path d="m51.032 329.138h14.216v62.822h-14.216z"></path><path d="m440.5 329.138h14.21v62.822h-14.21z"></path><path d="m505.736 310.619h-41.772-32.723-356.74-32.729-41.772v-33.198h80.835 65.951 65.958 65.964 80.242 65.957 80.829z"></path></g></g></svg>
      </a>
      <a href="/account/" class="vb-iconbtn" aria-label="Account">
        <img src="/assets/reader.svg" alt="" width="22" height="22">
      </a>
      <CartIcon client:load />
    </div>

    <button type="button" class="vb-mobile-toggle js-mobile-toggle" aria-label="Open menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<nav class="vb-mobile-nav js-mobile-nav" aria-label="Mobile navigation">
  <button type="button" class="vb-mobile-close js-mobile-close" aria-label="Close menu">✕</button>
  <a href="/">Shop</a>
  <a href="/collections">Collections</a>
  <a href="/field-notes">Field Notes</a>
  <a href="/#sell-to-us">Sell to us</a>
  <a href="/pages/shelf">Shelf</a>
  <a href="/account/">Account</a>
  <a href="/cart">Cart</a>
</nav>
