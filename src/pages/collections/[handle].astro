---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ProductCard from '../../components/ProductCard.astro';
import Pagination from '../../components/Pagination.astro';
import { getCollectionPage, parseSort, SORT_OPTIONS } from '../../lib/pagination';
import { getCustomerAccountsTokens } from '../../lib/customer-accounts';

const { handle } = Astro.params;

if (!handle) {
  return Astro.redirect('/404');
}

const rawPage = Number.parseInt(Astro.url.searchParams.get('page') ?? '1', 10);
const sort = parseSort(Astro.url.searchParams.get('sort'));

const result = await getCollectionPage({
  handle,
  page: rawPage,
  sort,
  buyerIP: Astro.clientAddress,
});

if (!result) {
  return Astro.redirect('/404');
}

const { collection, products, page, totalPages, totalCount, rangeStart, rangeEnd, sort: activeSort } = result;
const { accessToken } = getCustomerAccountsTokens(Astro.cookies);
const isAuthenticated = !!accessToken;
---

<Layout title={collection.title}>
  <Header slot="header" />

  <div class="vb-container">
    <div class="vb-coll-head">
      <div class="vb-coll-head__top">
        <div class="vb-coll-head__title">
          <div class="vb-coll-head__crumb">
            <a href="/">Shop</a>
            <span class="sep">/</span>
            <a href="/collections">All shelves</a>
            <span class="sep">/</span>
            <span class="now">{collection.title}</span>
          </div>
          <h1>{collection.title}</h1>
        </div>

        {collection.descriptionHtml && (
          <div class="vb-coll-head__desc" set:html={collection.descriptionHtml} />
        )}
      </div>
    </div>
  </div>

  <div class="vb-container">
    <div class="vb-coll" style="grid-template-columns: 1fr;">
      <div class="vb-coll__main">
        <div class="vb-coll__bar">
          <div class="left">
            {totalCount > 0 ? (
              <>Showing <strong>{rangeStart}–{rangeEnd}</strong> of {totalCount} books</>
            ) : (
              <>Showing <strong>0</strong> books</>
            )}
          </div>
          <div class="right">
            <form method="get" action={`/collections/${handle}/`} class="vb-sort">
              <label for="sort">Sort</label>
              <select id="sort" name="sort" onchange="this.form.submit()">
                {SORT_OPTIONS.map((option) => (
                  <option value={option.value} selected={option.value === activeSort}>{option.label}</option>
                ))}
              </select>
              <noscript>
                <button type="submit" class="vb-btn vb-btn--sm">Apply</button>
              </noscript>
            </form>
          </div>
        </div>

        <div class="vb-shelf">
          {products.map((product: any) => (
            <ProductCard product={product} isAuthenticated={isAuthenticated} />
          ))}
        </div>

        <Pagination page={page} totalPages={totalPages} baseUrl={`/collections/${handle}/`} sort={activeSort} />
      </div>
    </div>
  </div>

  <Footer slot="footer" />
</Layout>
