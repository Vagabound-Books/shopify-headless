---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { shopifyFetchServer } from '../../lib/shopify';
import { GET_COLLECTIONS } from '../../lib/queries';

const data = await shopifyFetchServer({
  query: GET_COLLECTIONS,
  variables: { first: 50 },
  buyerIP: Astro.clientAddress,
}).catch((err) => {
  console.error('[Shopify] Failed to fetch collections:', err);
  return null;
});

const collections = (data?.collections?.edges || [])
  .map((e: any) => e.node)
  .filter((c: any) => c.handle !== 'frontpage');
---

<Layout title="Collections">
  <Header slot="header" />

  <div class="vb-container">
    <div class="vb-coll-head" style="margin-bottom: 28px;">
      <div class="vb-sec-head__left">
        <div class="vb-eyebrow">Collections</div>
        <h1 style="font-family: var(--font-display); font-size: clamp(40px, 5vw, 64px); font-weight: 600; letter-spacing: -0.022em; line-height: 1.05; margin: 0;">
          Collections
        </h1>
        <p style="font-size: 21px; color: var(--ink-soft); line-height: 1.6; margin-top: 24px; font-family: var(--font-display); font-style: italic; max-width: 56ch;">
          The full collection, broken down by genre.
        </p>
      </div>
    </div>

    <div class="vb-collections">
      {collections.map((collection: any, index: number) => {
        const products = collection.products?.edges?.map((e: any) => e.node) || [];
        const productCount = products.length;
        return (
          <a class="vb-collection-row" href={`/collections/${collection.handle}`}>
            <div class="vb-collection-row__thumb">
              {collection.image ? (
                <img
                  src={collection.image.url}
                  alt={collection.image.altText || collection.title}
                  loading="lazy"
                  width="180"
                  height="260"
                  style="width: 100%; height: 100%; object-fit: cover; border-radius: var(--radius-sm);"
                />
              ) : (
                <div class="vb-cover vb-cover--marginalia" style="height: 100%;">
                  <div class="vb-cover__title" style="font-size: 14px;">{collection.title}</div>
                </div>
              )}
            </div>
            <div class="vb-collection-row__body">
              <div class="vb-collection-row__info">
                <h3>{collection.title}</h3>
                {collection.descriptionHtml && (
                  <div class="vb-collection-row__desc" set:html={collection.descriptionHtml} />
                )}
                {productCount > 0 && (
                  <span class="vb-collection-row__count">{productCount} {productCount === 1 ? 'book' : 'books'}</span>
                )}
              </div>
              {productCount > 0 && (
                <div class="vb-collection-row__slider vb-no-scrollbar" data-collection={collection.handle}>
                  <div class="vb-collection-row__pool" style="display:none;">
                    {products.map((product: any) => (
                      <div class="vb-collection-row__book">
                        {product.featuredImage ? (
                          <img
                            src={product.featuredImage.url}
                            alt={product.featuredImage.altText || product.title}
                            loading="lazy"
                            width="60"
                            height="84"
                            style="width: 100%; height: 100%; object-fit: cover; border-radius: 2px;"
                          />
                        ) : (
                          <div class="vb-cover vb-cover--marginalia" style="height: 100%;">
                            <div class="vb-cover__title" style="font-size: 8px;">{product.title}</div>
                          </div>
                        )}
                      </div>
                    ))}
                  </div>
                </div>
              )}
            </div>
            <span class="vb-collection-row__arrow">→</span>
          </a>
        );
      })}
    </div>
  </div>

  <Footer slot="footer" />
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('.vb-collection-row__slider').forEach(function(slider) {
      const pool = slider.querySelector('.vb-collection-row__pool');
      if (!pool) return;
      const books = Array.from(pool.children);
      // Fisher-Yates shuffle
      for (let i = books.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        const temp = books[i];
        books[i] = books[j];
        books[j] = temp;
      }
      const chosen = books.slice(0, 6);
      chosen.forEach(function(book) {
        (book as HTMLElement).style.display = '';
        slider.appendChild(book);
      });
    });
  });
</script>

<style>
  .vb-collections {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding-bottom: var(--space-9);
  }
  .vb-collection-row {
    display: grid;
    grid-template-columns: 140px 1fr auto;
    gap: 24px;
    align-items: center;
    padding: 20px 24px;
    background: var(--paper);
    text-decoration: none;
    transition: all 140ms var(--ease-page);
  }
  .vb-collection-row:nth-child(odd) {
    background: var(--buckram);
  }
  .vb-collection-row:nth-child(odd) .vb-collection-row__info,
  .vb-collection-row:nth-child(odd) .vb-collection-row__info :where(h3, .vb-collection-row__desc, div, span, a),
  .vb-collection-row:nth-child(odd) .vb-collection-row__count,
  .vb-collection-row:nth-child(odd) .vb-collection-row__arrow {
    color: var(--paper);
  }
  .vb-collection-row:nth-child(odd) .vb-collection-row__info a {
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .vb-collection-row:nth-child(odd):hover {
    background: #0d273b;
  }
  .vb-collection-row:hover {
    background: var(--paper-soft);
  }
  .vb-collection-row:hover .vb-collection-row__arrow {
    color: var(--accent);
  }
  .vb-collection-row__thumb {
    height: 190px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    flex-shrink: 0;
  }
  .vb-collection-row__body {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 24px;
    min-width: 0;
  }
  .vb-collection-row__info {
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 0 0 auto;
    min-width: 0;
  }
  .vb-collection-row__info h3 {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 600;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.01em;
  }
  .vb-collection-row__desc {
    margin: 0;
    font-size: 14px;
    color: var(--ink-soft);
    line-height: 1.5;
    max-width: 48ch;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .vb-collection-row__desc :global(p) {
    margin: 0 0 0.5em;
  }
  .vb-collection-row__desc :global(p:last-child) {
    margin-bottom: 0;
  }
  .vb-collection-row__count {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: var(--tracking-eyebrow);
    color: var(--ink-muted);
    margin-top: 2px;
  }
  .vb-collection-row__slider {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    padding-bottom: 4px;
    flex: 1 1 0;
    min-width: 0;
    justify-content: flex-end;
  }
  .vb-collection-row__book {
    flex: 0 0 auto;
    width: 80px;
    height: 112px;
    border-radius: 2px;
    overflow: hidden;
    box-shadow: 0 2px 6px -2px rgba(0,0,0,0.15);
  }
  .vb-collection-row__arrow {
    font-family: var(--font-mono);
    font-size: 20px;
    color: var(--ink-muted);
    transition: color 140ms var(--ease-page);
    padding-right: 4px;
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .vb-collection-row {
      grid-template-columns: 110px 1fr auto;
      gap: 16px;
      padding: 16px;
    }
    .vb-collection-row__thumb {
      height: 150px;
    }
    .vb-collection-row__body {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
    }
    .vb-collection-row__slider {
      justify-content: flex-start;
      width: 100%;
    }
    .vb-collection-row__info h3 {
      font-size: 18px;
    }
    .vb-collection-row__desc {
      -webkit-line-clamp: 2;
      max-width: none;
    }
    .vb-collection-row__book {
      width: 64px;
      height: 90px;
    }
  }
</style>
