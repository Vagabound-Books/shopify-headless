---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCustomer } from '../../lib/auth';
import { isCustomerAccountsEnabled, buildAuthorizeUrl } from '../../lib/customer-accounts';

const customer = await getCustomer(Astro.cookies);
if (customer) {
  return Astro.redirect('/account/');
}

if (isCustomerAccountsEnabled()) {
  return Astro.redirect(buildAuthorizeUrl(Astro.cookies));
}
---

<Layout title="Create Account">
  <Header slot="header" />

  <div class="vb-container" style="padding-block: var(--space-9);">
    <div style="max-width: 480px; margin: 0 auto; text-align: center;">
      <div class="vb-eyebrow" style="margin-bottom: 18px;">Account</div>
      <h1 style="font-family: var(--font-display); font-size: clamp(32px, 4vw, 48px); font-weight: 600; letter-spacing: -0.022em; line-height: 1.05; margin: 0 0 12px;">
        Create account
      </h1>
      <p style="font-size: 17px; color: var(--ink-soft); line-height: 1.6; margin: 0 0 32px;">
        Customer Accounts API is not configured. Please contact support.
      </p>
    </div>
  </div>

  <Footer slot="footer" />
</Layout>
