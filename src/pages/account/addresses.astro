---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCustomer } from '../../lib/auth';

const customer = await getCustomer(Astro.cookies);
if (!customer) {
  return Astro.redirect('/account/login');
}

const fullName = [customer.firstName, customer.lastName].filter(Boolean).join(' ') || 'Account';
const addresses = (customer.addresses?.edges || []).map((e: any) => e.node);
const defaultAddressId = customer.defaultAddress?.id;

const navItems = [
  { label: 'Overview', href: '/account', active: false },
  { label: 'Orders', href: '/account/orders', active: false },
  { label: 'Addresses', href: '/account/addresses', active: true },
];
---

<Layout title="Addresses">
  <Header slot="header" />

  <div class="vb-container" style="padding-block: var(--space-9);">
    <div style="display: grid; grid-template-columns: 220px 1fr; gap: 64px; align-items: start;">
      <aside style="position: sticky; top: 120px;">
        <div style="font-family: var(--font-display); font-size: 22px; font-weight: 600; margin-bottom: 24px;">{fullName}</div>
        <nav style="display: flex; flex-direction: column; gap: 4px;">
          {navItems.map((item) => (
            <a
              href={item.href}
              style={`
                text-decoration: none;
                padding: 8px 12px;
                border-radius: var(--radius-sm);
                font-size: 14px;
                font-weight: 600;
                transition: background 140ms var(--ease-page);
                ${item.active ? 'background: var(--paper-soft); color: var(--ink);' : 'color: var(--ink-soft);'}
              `}
            >
              {item.label}
            </a>
          ))}
          <form action="/api/logout" method="POST" style="margin-top: 8px;">
            <button type="submit" style="background: transparent; border: 0; padding: 8px 12px; font-size: 14px; font-weight: 600; color: var(--ink-muted); cursor: pointer; width: 100%; text-align: left; border-radius: var(--radius-sm); transition: background 140ms var(--ease-page);">Sign out</button>
          </form>
        </nav>
      </aside>

      <div style="min-width: 0;">
        <div class="vb-eyebrow" style="margin-bottom: 18px;">Account</div>
        <h1 style="font-family: var(--font-display); font-size: clamp(32px, 4vw, 48px); font-weight: 600; letter-spacing: -0.022em; line-height: 1.05; margin: 0 0 48px;">Addresses</h1>

        {addresses.length === 0 ? (
          <div style="padding: 48px 24px; text-align: center; border: 1px dashed var(--rule-firm); border-radius: var(--radius-md);">
            <p style="margin: 0; color: var(--ink-muted); font-size: 15px;">No saved addresses.</p>
          </div>
        ) : (
          <div style="display: flex; flex-direction: column; gap: 16px; margin-bottom: 48px;">
            {addresses.map((addr: any) => {
              const isDefault = addr.id === defaultAddressId;
              return (
                <div style={`padding: 24px; border: 1px solid ${isDefault ? 'var(--rule-firm)' : 'var(--rule-soft)'}; border-radius: var(--radius-md); background: ${isDefault ? 'var(--paper-soft)' : 'transparent'};`}>
                  <div style="font-family: var(--font-display); font-size: 18px; font-weight: 600; color: var(--ink); margin-bottom: 4px;">
                    {addr.name || `${addr.firstName || ''} ${addr.lastName || ''}`.trim() || 'Address'}
                    {isDefault && <span class="vb-pill" style="margin-left: 10px; vertical-align: 2px;">Default</span>}
                  </div>
                  <address style="font-style: normal; font-size: 15px; color: var(--ink-soft); line-height: 1.6;">
                    <div>{addr.address1}{addr.address2 ? `, ${addr.address2}` : ''}</div>
                    <div>{addr.city}{addr.province ? `, ${addr.province}` : ''} {addr.zip}</div>
                    <div>{addr.country}</div>
                    {addr.phone && <div style="margin-top: 4px;">{addr.phone}</div>}
                  </address>
                </div>
              );
            })}
          </div>
        )}
      </div>
    </div>
  </div>

  <Footer slot="footer" />
</Layout>

<style>
  @media (max-width: 900px) {
    .vb-container > div {
      grid-template-columns: 1fr !important;
      gap: 32px !important;
    }
    aside {
      position: static !important;
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
    }
    aside nav {
      flex-direction: row !important;
      flex-wrap: wrap;
    }
    aside form {
      margin-top: 0 !important;
      margin-left: auto;
    }
  }
</style>
