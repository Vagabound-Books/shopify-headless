---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { shopifyFetchServer } from '../../lib/shopify';
import { GET_PAGE_BY_HANDLE } from '../../lib/queries';

const { handle } = Astro.params;

if (!handle) {
  return Astro.redirect('/404');
}

const data = await shopifyFetchServer({
  query: GET_PAGE_BY_HANDLE,
  variables: { handle },
}).catch(() => null);

const page = data?.page;

if (!page) {
  return Astro.redirect('/404');
}
---

<Layout title={page.title}>
  <Header slot="header" />

  <div class="vb-container">
    <div class="vb-coll-head">
      <div class="vb-coll-head__top">
        <div class="vb-coll-head__title">
          <div class="vb-coll-head__crumb">
            <a href="/">Shop</a>
            <span class="sep">/</span>
            <span class="now">{page.title}</span>
          </div>
          <h1>{page.title}</h1>
        </div>
      </div>
    </div>

    <div class="vb-page-body" set:html={page.body} style="margin-top: 32px; max-width: 720px; line-height: 1.7;" />
  </div>

  <Footer slot="footer" />
</Layout>
