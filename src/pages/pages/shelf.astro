---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ShelfPage from '../../components/ShelfPage.tsx';
import {
  customerAccountsFetch,
  getCustomerAccountsTokens,
} from '../../lib/customer-accounts';
import { CUSTOMER_WISHLIST_QUERY } from '../../lib/queries';
import type { ShelfItem } from '../../lib/shelf';

// Fetch cloud wishlist for authenticated customers
let cloudItems: ShelfItem[] = [];
const { accessToken } = getCustomerAccountsTokens(Astro.cookies);
if (accessToken) {
  try {
    const data = await customerAccountsFetch(
      CUSTOMER_WISHLIST_QUERY,
      {},
      accessToken
    );
    const metafield = data?.customer?.metafields?.[0];
    if (metafield?.value) {
      try {
        const parsed = JSON.parse(metafield.value);
        if (Array.isArray(parsed)) {
          cloudItems = parsed;
        }
      } catch {
        // ignore invalid JSON
      }
    }
  } catch (err) {
    console.error('[Wishlist] Failed to fetch cloud wishlist:', err);
  }
}
---

<Layout title="Shelf">
  <Header slot="header" />

  <div class="vb-container">
    <div class="vb-coll-head">
      <div class="vb-coll-head__top">
        <div class="vb-coll-head__title">
          <div class="vb-coll-head__crumb">
            <a href="/">Shop</a>
            <span class="sep">/</span>
            <span class="now">Shelf</span>
          </div>
          <h1>Your shelf</h1>
        </div>
      </div>
    </div>
  </div>

  <div class="vb-container">
    <ShelfPage client:load cloudItems={cloudItems} />
  </div>

  <Footer slot="footer" />
</Layout>
