---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ShelfPage from '../../components/ShelfPage.tsx';
---

<Layout title="Shelf">
  <Header slot="header" />

  <div class="vb-container">
    <div class="vb-coll-head">
      <div class="vb-coll-head__top">
        <div class="vb-coll-head__title">
          <div class="vb-coll-head__crumb">
            <a href="/">Shop</a>
            <span class="sep">/</span>
            <span class="now">Shelf</span>
          </div>
          <h1>Your shelf</h1>
        </div>
      </div>
    </div>
  </div>

  <div class="vb-container">
    <ShelfPage client:load />
  </div>

  <Footer slot="footer" />
</Layout>
