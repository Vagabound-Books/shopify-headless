---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { shopifyFetchServer } from '../../lib/shopify';
import { GET_ARTICLE_BY_HANDLE } from '../../lib/queries';

const { handle } = Astro.params;

if (!handle) {
  return Astro.redirect('/404');
}

const data = await shopifyFetchServer({
  query: GET_ARTICLE_BY_HANDLE,
  variables: { blogHandle: 'field-notes', articleHandle: handle },
}).catch((err) => {
  console.error('[Shopify] Failed to fetch article:', err);
  return null;
});

const article = data?.blog?.articleByHandle;

if (!article) {
  return Astro.redirect('/404');
}

const date = new Date(article.publishedAt).toLocaleDateString('en-GB', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const volumeMeta = article.metafields?.find((m: any) => m?.key === 'volume');
const volumeNumber = volumeMeta?.value || 'I';
---

<Layout title={article.title}>
  <Header slot="header" />

  <article class="vb-container vb-article">
    <div class="vb-article__meta">
      <span class="stamp">Field Notes — Volume {volumeNumber}</span>
      <span>{date}</span>
    </div>

    <h1 style="font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.05; margin: 16px 0 32px; max-width: 900px;">
      {article.title}
    </h1>

    {article.image && (
      <img
        src={article.image.url}
        alt={article.image.altText || article.title}
        width="1200"
        height="675"
        style="aspect-ratio: 16/9; object-fit: cover; border-radius: var(--radius-sm); margin-bottom: 48px;"
      />
    )}

    <div class="vb-article__body" set:html={article.contentHtml || article.excerptHtml} />

    <div class="vb-article__author" style="margin-top: 64px; padding-top: 32px; border-top: 1px solid var(--rule-soft);">
      <span style="color: var(--ink-muted); font-size: var(--type-sm);">By {article.author?.name || 'Vagabound'}</span>
    </div>
  </article>

  <Footer slot="footer" />
</Layout>
