---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CartPage from '../components/CartPage.tsx';
---

<Layout title="Cart">
  <Header slot="header" />

  <div class="vb-container">
    <div class="vb-coll-head">
      <div class="vb-coll-head__top">
        <div class="vb-coll-head__title">
          <div class="vb-coll-head__crumb">
            <a href="/">Shop</a>
            <span class="sep">/</span>
            <span class="now">Cart</span>
          </div>
          <h1>Your basket</h1>
        </div>
      </div>
    </div>
  </div>

  <div class="vb-container" style="max-width: 720px; margin-top: 32px;">
    <CartPage client:load />
  </div>

  <Footer slot="footer" />
</Layout>
